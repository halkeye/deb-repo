{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>halkeye/halkeye//.github/renovate/base.json5"
  ],
  "minimumReleaseAge": "7 days",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/packages/.+\\.yaml$/"
      ],
      "matchStrings": [
        "version: \"(?<currentValue>.+?)\" # repo: (?<depName>.*)"
      ],
      "datasourceTemplate": "github-releases"
    }
  ]
}
